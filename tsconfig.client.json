{
  "extends": "./tsconfig.json",
  "include": [
    "client/src/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "server/**/*",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": [
      "ES2020",
      "dom",
      "dom.iterable"
    ]
  }
}