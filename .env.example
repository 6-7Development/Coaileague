# WorkforceOS - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE (Neon PostgreSQL)
# ============================================
DATABASE_URL=postgresql://username:password@host/database?sslmode=require
PGHOST=your-host.neon.tech
PGDATABASE=your-database
PGUSER=your-username
PGPASSWORD=your-password
PGPORT=5432

# ============================================
# SESSION & AUTHENTICATION
# ============================================
SESSION_SECRET=your-super-secret-session-key-min-32-characters
NODE_ENV=production  # development | production

# ============================================
# STRIPE (Payment Processing & Platform Fees)
# ============================================
# Production Keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key

# Test Keys (for development)
TESTING_STRIPE_SECRET_KEY=sk_test_your_test_key
TESTING_VITE_STRIPE_PUBLIC_KEY=pk_test_your_test_public_key

# ============================================
# EMAIL NOTIFICATIONS (Resend)
# ============================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# SMS NOTIFICATIONS (Twilio) - Optional Add-on
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# ============================================
# CUSTOM DOMAIN & DEPLOYMENT
# ============================================
# Set this to your production domain (no http/https)
VITE_APP_URL=app.workforceos.com  # or your custom domain
# Auto-detect in production: https://app.workforceos.com

# Replit Deployment (auto-set by Replit)
REPLIT_DEPLOYMENT=1  # Set automatically when published

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Override default platform fee percentage
DEFAULT_PLATFORM_FEE=5.00  # 5%

# Enable/disable features globally
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_GPS_TRACKING=true
ENABLE_AUTOMATED_PAYROLL=false  # Coming soon

# ============================================
# MONITORING & LOGGING (Future)
# ============================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# LOGTAIL_TOKEN=your_logtail_token

# ============================================
# API INTEGRATIONS (Future Add-ons)
# ============================================
# CHECKR_API_KEY=test_xxx  # Background checks
# ADP_CLIENT_ID=xxx  # Payroll integration
# QUICKBOOKS_CLIENT_ID=xxx  # Accounting integration
