# ============================================================================
# UNIVERSAL CONFIGURATION - AutoForce™ Migration & Onboarding
# ============================================================================

# MIGRATION SETTINGS
VITE_AI_MIGRATION_PROVIDER=gemini
VITE_AI_MIGRATION_MODEL=gemini-2.0-flash-exp
VITE_SCHEDULE_DEFAULT_START_TIME=09:00
VITE_SCHEDULE_DEFAULT_END_TIME=17:00
VITE_PAYROLL_DEFAULT_STATUS=draft
VITE_INVOICE_DEFAULT_STATUS=draft
VITE_INVOICE_DUE_DAYS=30
VITE_MIGRATION_JOB_PREFIX=MIG
VITE_MIGRATION_DOC_PREFIX=DOC
VITE_MIGRATION_REC_PREFIX=REC
VITE_MIGRATION_MAX_SIZE=52428800
VITE_MIGRATION_MAX_RECORDS=1000
VITE_MIGRATION_COOLDOWN=5
VITE_FUZZY_EMPLOYEE_THRESHOLD=0.85
VITE_FUZZY_CLIENT_THRESHOLD=0.80
VITE_FUZZY_PARTIAL_MATCH=true

# ONBOARDING SETTINGS
VITE_ONBOARDING_FROM_EMAIL=onboarding@autoforce.ai
VITE_ONBOARDING_SUPPORT_EMAIL=support@autoforce.ai
VITE_ONBOARDING_NOTIFY_MANAGER=true
VITE_ONBOARDING_SEND_WELCOME=true
VITE_ONBOARDING_SEND_COMPLETION=true
VITE_ONBOARDING_CELEBRATION=true
VITE_ONBOARDING_DAYS=14
VITE_ONBOARDING_REMINDER_DAYS=3
VITE_ONBOARDING_AUTO_REMINDERS=true

# WORKFLOW SETTINGS
VITE_WORKFLOW_MANAGER_APPROVAL_HOURS=24
VITE_WORKFLOW_SUPERVISOR_APPROVAL_HOURS=48
VITE_WORKFLOW_ADMIN_APPROVAL_HOURS=72
VITE_WORKFLOW_AUTO_ESCALATE=true
VITE_WORKFLOW_PAYROLL_ENABLED=true
VITE_WORKFLOW_INVOICE_ENABLED=true
VITE_WORKFLOW_SCHEDULE_ENABLED=true
VITE_WORKFLOW_REPORT_ENABLED=true
VITE_WORKFLOW_ALLOW_RESUBMIT=true
VITE_WORKFLOW_REQUIRE_CHANGES=true
VITE_WORKFLOW_NOTIFY_REJECTION=true
VITE_WORKFLOW_ESCALATION_EMAILS=admin@autoforce.ai
VITE_WORKFLOW_REMIND ER_HOURS=24
VITE_WORKFLOW_RETENTION_DAYS=2555

# METRICS SETTINGS
VITE_METRICS_ENABLED=true
VITE_METRICS_DETAILED=true
VITE_METRICS_SAMPLING_RATE=1.0
VITE_HEALTH_CHECK_INTERVAL=60
VITE_PERF_SCHEDULE_MAX_MS=30000
VITE_PERF_PAYROLL_MAX_MS=60000
VITE_PERF_INVOICE_MAX_MS=15000
VITE_PERF_REPORT_MAX_MS=45000

# FILE CABINET SETTINGS
VITE_FILE_CABINET_ENABLED=false
VITE_FILE_CABINET_PROVIDER=local
VITE_FILE_CABINET_MAX_SIZE=52428800
VITE_FILE_CABINET_STORAGE=object-storage
VITE_DOC_CERT_WARNING_DAYS=30
VITE_DOC_BG_WARNING_DAYS=365
VITE_DOC_INS_WARNING_DAYS=60
VITE_FILE_CABINET_COMPLIANCE_CHECK=false
VITE_FILE_CABINET_EXTERNAL_SHARE=false
VITE_FILE_CABINET_SHARE_DAYS=7

# INVOICE ADJUSTMENT SETTINGS
VITE_ADJUSTMENT_DISCOUNT_ENABLED=true
VITE_DISCOUNT_MAX_PERCENT=50
VITE_ADJUSTMENT_CREDIT_ENABLED=true
VITE_ADJUSTMENT_REFUND_ENABLED=true
VITE_ADJUSTMENT_WRITEOFF_ENABLED=false
VITE_DISCOUNT_REQUIRES_APPROVAL=true
VITE_ADJUSTMENT_MULTI_LEVEL=false
VITE_ADJUSTMENT_MIN_AMOUNT=0.01
VITE_ADJUSTMENT_MAX_AMOUNT=999999.99
VITE_ADJUSTMENT_PERSIST=true
VITE_ADJUSTMENT_SYNC_STRIPE=false

# ============================================================================
# PLAID ACH PAYROLL DIRECT DEPOSIT
# ============================================================================

# Plaid API credentials (https://dashboard.plaid.com/developers/keys)
# Use 'sandbox' for testing, 'production' for live
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=

# ============================================================================
# SECURITY - VIRUS SCANNING
# ============================================================================

# Enable/disable virus scanning on file uploads (default: true)
VIRUS_SCAN_ENABLED=true

# Scan mode: 'strict' (block suspicious files) or 'standard' (block only confirmed malware)
VIRUS_SCAN_MODE=strict

# VirusTotal API key for cloud-based scanning (optional but recommended)
# Get your API key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=


# PLAID ACH PAYROLL DIRECT DEPOSIT
# Plaid API credentials (https://dashboard.plaid.com/developers/keys)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# Webhook signing secret — Plaid Dashboard → Team Settings → Keys → Webhook secret
# Without this, incoming Plaid webhook events return 500 (server still starts — warnOnly)
PLAID_WEBHOOK_SECRET=
# 64-char hex key for AES-256-GCM encryption of stored Plaid access tokens
# Generate: openssl rand -hex 32
# REQUIRED (hard error) when PLAID_CLIENT_ID is set — no fallback allowed
PLAID_ENCRYPTION_KEY=

# ============================================================================
# STRIPE BILLING
# ============================================================================
# Live key: sk_live_... | Test key: sk_test_...
STRIPE_SECRET_KEY=
# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe Billing Meter ID for AI token usage tracking
# Create: dashboard.stripe.com → Billing → Meters → event name: ai_tokens_used
STRIPE_TOKEN_METER_ID=

# ============================================================================
# CORE REQUIRED SECRETS (all environments)
# ============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Session secret — minimum 32 random characters
# Generate: openssl rand -base64 48
SESSION_SECRET=

# ============================================================================
# PRODUCTION-ONLY REQUIRED
# ============================================================================
# 64-char hex string for AES-256-GCM field-level encryption
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=
# Comma-separated list of allowed HTTPS origins (no trailing slash)
ALLOWED_ORIGINS=https://app.coaileague.com,https://coaileague.com