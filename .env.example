# ============================================
# WorkforceOS - Environment Variables Template
# For Render Deployment & Independent Development
# ============================================
# REQUIRED: These MUST be set for the app to run
# OPTIONAL: These enable additional features but app works without them
# 
# IMPORTANT:
# - Set all REQUIRED vars BEFORE first deploy on Render
# - Health check endpoint: /health
# - Generate SESSION_SECRET with: openssl rand -base64 32
# ============================================

# ============================================
# DATABASE (REQUIRED - Neon PostgreSQL)
# ============================================
# CURRENT SETUP: Uses Neon serverless driver
# This driver ONLY works with Neon databases
# Format: postgresql://username:password@hostname.neon.tech/database?sslmode=require
#
# Works on: Replit, Render, Vercel, or any platform
# Recommendation: Keep your existing Neon database when migrating to Render
#
# If you need Render's managed Postgres instead (ADVANCED):
# - Switch to pg driver in server/db.ts (see migration guide)
# - Use drizzle-orm/node-postgres adapter
# - Then use Render internal URL format
DATABASE_URL=postgresql://username:password@hostname.neon.tech/database?sslmode=require

# Legacy Postgres env vars (auto-set by some platforms)
PGHOST=your-host.neon.tech
PGDATABASE=your-database
PGUSER=your-username
PGPASSWORD=your-password
PGPORT=5432

# ============================================
# SESSION & AUTHENTICATION (REQUIRED)
# ============================================
# CRITICAL: Generate a secure random string (min 32 chars)
# Example: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-min-32-characters

# Environment (affects logging, error handling, Vite setup)
NODE_ENV=production  # development | production

# Port (auto-set by Render, defaults to 5000)
PORT=5000

# ============================================
# STRIPE (REQUIRED for subscription payments)
# ============================================
# Production Keys (live environment)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key

# Test Keys (for development only)
TESTING_STRIPE_SECRET_KEY=sk_test_your_test_key
TESTING_VITE_STRIPE_PUBLIC_KEY=pk_test_your_test_public_key

# ============================================
# AI SERVICES (OPTIONAL - enables AI features)
# ============================================
# OpenAI (for AI chat, analytics, etc.)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude (alternative to OpenAI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Note: App gracefully degrades if AI keys not provided

# ============================================
# EMAIL NOTIFICATIONS (OPTIONAL - Resend)
# ============================================
# Without this, email features will be disabled but app still works
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# SMS NOTIFICATIONS (OPTIONAL - Twilio)
# ============================================
# Without these, SMS features will be disabled but app still works
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# ============================================
# OBJECT STORAGE (OPTIONAL - for file uploads)
# ============================================
# Google Cloud Storage or similar
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-gcs-bucket-id
PUBLIC_OBJECT_SEARCH_PATHS=/public
PRIVATE_OBJECT_DIR=/.private

# ============================================
# DEPLOYMENT & DOMAIN (Auto-detected on Render)
# ============================================
# These are usually set automatically by hosting platform
# VITE_APP_URL=https://app.workforceos.com
# REPLIT_DEPLOYMENT=1  # Set by Replit when published

# ============================================
# MONITORING & LOGGING (FUTURE)
# ============================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# LOGTAIL_TOKEN=your_logtail_token
